  ttest_output <- function(var, label) {
    male   <- garmin %>% filter(Gender == "Male")   %>% pull(all_of(var)) %>% na.omit()
    female <- garmin %>% filter(Gender == "Female") %>% pull(all_of(var)) %>% na.omit()
    if (length(male) > 0 && length(female) > 0) {
      t <- t.test(male, female)
      cat("Welch two-sample t-test —", label, "\n")
      cat(sprintf("Male   M = %.2f (SD = %.2f, n = %d)\n", mean(male), sd(male), length(male)))
      cat(sprintf("Female M = %.2f (SD = %.2f, n = %d)\n", mean(female), sd(female), length(female)))
      cat(sprintf("t(%s) = %.3f, p = %s\n",
                  round(t$parameter, 1), t$statistic, format.pval(t$p.value, digits = 3)))
      cat(sprintf("95%% CI: [%.3f, %.3f]\n", t$conf.int[1], t$conf.int[2]))
      cat(ifelse(t$p.value < 0.05, "→ Statistically significant (p < .05)",
                 "→ Not significant (p ≥ .05)"))
    }
  }
