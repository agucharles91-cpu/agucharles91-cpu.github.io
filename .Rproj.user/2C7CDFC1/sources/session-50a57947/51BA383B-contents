    m <- lag_m()
    if (is.null(m)) return(datatable(data.frame(Error = "Model could not be fitted")))
    ct <- summary(m)$coefficients
    ci <- confint(m)
    tbl <- data.frame(
      Term      = rownames(ct),
      Estimate  = round(ct[,1], 4),
      `Std.Error`= round(ct[,2], 4),
      `CI 2.5%` = round(ci[,1], 4),
      `CI 97.5%`= round(ci[,2], 4),
      `p-value` = sapply(ct[,4], function(p) {
        if (p < 0.001) "< 0.001" else as.character(round(p, 3))
      }),
      check.names = FALSE
    )
    datatable(tbl, rownames = FALSE, options = list(dom = "t", pageLength = 10)) %>%
      formatStyle("p-value",
