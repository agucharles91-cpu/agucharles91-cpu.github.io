fig_card <- function(label, plot_id, height = "300px", caption = NULL) {
  div(class = "acad-card",
    div(class = "card-label", label),
    withSpinner(plotlyOutput(plot_id, height = height),
                type = 6, color = "#2C5F8A", size = 0.6),
    if (!is.null(caption)) div(class = "fig-caption", caption)
  )
}

fig_card_static <- function(label, plot_id, height = "300px", caption = NULL) {
  div(class = "acad-card",
    div(class = "card-label", label),
    withSpinner(plotOutput(plot_id, height = height),
                type = 6, color = "#2C5F8A", size = 0.6),
    if (!is.null(caption)) div(class = "fig-caption", caption)
  )
}

kpi_box_ui <- function(label, output_id, sub = NULL) {
  div(class = "kpi-box",
    div(class = "kpi-label", label),
    div(class = "kpi-value", textOutput(output_id, inline = TRUE)),
    if (!is.null(sub)) div(class = "kpi-sub", sub)
  )
}

