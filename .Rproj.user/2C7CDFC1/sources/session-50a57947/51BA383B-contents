            "Violin with embedded box (IQR) and mean line. Individual athlete-days jittered within each group."
          ),
          div(class = "acad-card",
            div(class = "card-label", "Statistical test — recovery score"),
            verbatimTextOutput("ttest_rec")
          )
        ),
        column(6,
          fig_card("Figure 13 — Sleep quality % by sex",
            "sex_sleep", "290px",
            "Distribution of restorative sleep percentage (Deep + REM / Total) by sex."
          ),
          div(class = "acad-card",
            div(class = "card-label", "Statistical test — sleep quality"),
            verbatimTextOutput("ttest_sleep")
          )
        )
      ),
      fluidRow(
        column(6, fig_card(
          "Figure 14 — Training distance by sex",
          "sex_distance", "280px",
          "Daily training distance (km) including rest days (TV = 0)."
        )),
        column(6,
          div(class = "acad-card",
            div(class = "card-label", "Table 3 — Descriptive statistics by sex"),
            DTOutput("sex_summary_tbl"),
            div(class = "fig-caption",
              "Means computed across all athlete-days. BMI = Weight (kg) / Height (m)².")
          )
        )
      )
    )
  ),

  # ── TAB 5: INDIVIDUAL EXPLORER ──────────────────────────────────────────────
  tabPanel("Individual Explorer",
    div(class = "page-body",
      page_head("Individual Participant Explorer",
        "Population averages mask meaningful individual variation. Select one or two participants to examine their personal training–sleep–recovery story over time."),

      fluidRow(
        column(3, div(class = "filter-panel",
          h5("Participant A"),
          selectInput("pid_a", NULL, choices = USERS, selected = USERS[1]),
          uiOutput("demo_a"),
          br(),
          checkboxInput("compare_on", "Compare with Participant B", FALSE),
          conditionalPanel("input.compare_on == true",
            br(),
            tags$div(style = "font-family:'Libre Baskerville',serif; font-size:11px;
                              font-weight:700; text-transform:uppercase; letter-spacing:0.12em;
                              color:#444; margin-bottom:10px;", "Participant B"),
            selectInput("pid_b", NULL, choices = USERS, selected = USERS[2]),
            uiOutput("demo_b")
          )
        )),
        column(9,
          fig_card("Figure 15A — Recovery & sleep timeline (Participant A)",
            "timeline_a", "340px",
            "Blue line = RHR deviation from 7-day rolling baseline. Bars = total sleep duration (h). Dashed line at zero = personal baseline. Triangles mark training days, coloured by type."),
          conditionalPanel("input.compare_on == true",
            fig_card("Figure 15B — Recovery & sleep timeline (Participant B)",
              "timeline_b", "320px",
              "Same format as Figure 15A. Y-axes are independent to show within-person variation."
            )
          )
        )
      ),
      fluidRow(
        column(6, fig_card(
          "Figure 16 — Sleep stage profile (Participant A)",
          "stages_a", "270px",
          "Stacked area chart of Deep / Light / REM sleep proportion over time. Only available for participants with 4-stage Garmin firmware."
        )),
        column(6, fig_card(
          "Figure 17 — Last night's sleep → today's recovery",
          "lag_scatter_a", "270px",
          "Each point = one athlete-day. X = TSD last night (lag 1d). Y = today's recovery score. Downward slope indicates a positive lagged relationship between sleep and recovery."
        ))
      ),
      div(class = "acad-card",
        div(class = "card-label", "Personal summary statistics (Participant A)"),
        uiOutput("personal_summary_a")
      ),
      conditionalPanel("input.compare_on == true",
        div(class = "acad-card",
          div(class = "card-label", "Participant A vs B — comparison table"),
          acad_note(tags$strong("Exploratory only: "),
            "Differences may reflect age, fitness level, training volume,",
            " or device-specific recording artefacts rather than true physiological differences."),
          DTOutput("compare_tbl")
        )
      )
    )
  ),

  # ── TAB 6: RELATIONSHIPS ────────────────────────────────────────────────────
  tabPanel("Relationships",
    div(class = "page-body",
      page_head("Variable Relationships",
        "Pearson / Spearman correlations and multivariate visualisation of recovery determinants."),

      acad_note(tags$strong("Interpretation guide: "),
        "Pearson r values range from −1 (perfect negative) to +1 (perfect positive). ",
        "Values ≥ |0.3| are considered practically meaningful in exercise science contexts. ",
        "Spearman is recommended as default given the skewed distributions of TSD, SessionLoad, and SF."),

      fluidRow(
        column(5, fig_card(
          "Figure 18 — Predictors of recovery score (Spearman r)",
          "rel_corr_bars", "350px",
          "Horizontal bars show Spearman ρ with recovery score. Green = positive; red = negative. Computed on pairwise complete observations."
        )),
        column(7, fig_card_static(
          "Figure 19 — Correlation matrix",
          "rel_corr_heatmap", "350px",
          "Pearson correlation matrix. Diverging palette: blue = positive, red = negative, white ≈ zero. Values overlaid for readability."
        ))
      ),
      fluidRow(
        column(6,
          div(class = "filter-panel", style = "margin-bottom:16px;",
            h5("Scatterplot Explorer"),
            fluidRow(
              column(6, selectInput("sc_x", "X variable",
                choices = c("SessionLoad","TSD","SE","SF","RelativeIntensity",
                            "VO2max_imputed_final","DailyTotalSteps",
                            "DailyBodyBattery.chargedValue","HR_range"),
                selected = "SessionLoad")),
              column(6, selectInput("sc_y", "Y variable",
                choices = c("RecoveryScore","TSD","SE","SF","RelativeIntensity",
                            "VO2max_imputed_final","SleepQuality_pct"),
                selected = "RecoveryScore"))
            )
          ),
          fig_card("Figure 20 — Scatterplot explorer",
            "rel_scatter", "290px",
            "Each point = one athlete-day, coloured by participant. LOESS smoother with 95% CI. Spearman ρ displayed in subtitle.")
        ),
        column(6, fig_card(
          "Figure 21 — Recovery landscape: sleep quality × daily steps (GAM surface)",
          "rel_gam", "380px",
          "GAM surface fitted to recovery score as a function of sleep quality (%) and daily steps. Observed points overlaid, sized by SessionLoad intensity."
        ))
      )
    )
  ),

  # ── TAB 7: METHODS & QUALITY ────────────────────────────────────────────────
  tabPanel("Methods & Quality",
    div(class = "page-body",
      page_head("Methods & Data Quality",
        "Variable dictionary, data quality notes, cohort definitions, and reproducibility information."),

      fluidRow(
        column(12, div(class = "acad-card",
          div(class = "card-label", "Variable dictionary (searchable)"),
          DTOutput("dict_tbl")
        ))
      ),
      fluidRow(
        column(6,
          div(class = "acad-card",
            div(class = "card-label", "Data quality notes"),
            acad_warn(tags$strong("SE = 1.0 values: "),
              "Sleep Efficiency values of exactly 1.0 indicate Garmin detected zero awake time —",
              " a device floor, not truly perfect sleep. Retained but flagged."),
            acad_warn(tags$strong("Body Battery: "),
              "P008 has 0% coverage. P009 and P010 have 18–24% missing.",
              " Treat as supplementary only."),
            acad_warn(tags$strong("Sleep staging: "),
              "P006, P013, and P015 lack 4-stage data (legacy firmware). Stage-level analyses",
              " restricted to the 'full' cohort (11 participants)."),
            acad_warn(tags$strong("VO2max: "),
              "Always use VO2max_imputed_final (LOCF-imputed). ActivitiesVO2MaxValue is",
              " outdoor-running-only and 70% missing."),
            acad_warn(tags$strong("DailyActivityLoad: "),
              "Mirrors step count in this dataset. Do not use alongside DailyTotalSteps.")
          )
        ),
        column(6,
          div(class = "acad-card",
            div(class = "card-label", "Cohort definitions & participant breakdown"),
            acad_note(tags$strong("'full' cohort (9,700 rows): "),
              "Valid sleep stage proportions. 11 participants.",
              " Use for DeepSleepProp, REMSleepProp_final, SleepScore analyses.",
              tags$br(), tags$br(),
              tags$strong("'no_sleep_stages' cohort (3,060 rows): "),
              "P006 / P013 / P015. Can be included in TSD, SE, SF, RHR_dev_7d analyses."),
            DTOutput("cohort_tbl")
          ),
          br(),
          div(class = "acad-card",
            div(class = "card-label", "Figure 22 — Missing data audit"),
            withSpinner(plotlyOutput("missing_plot", height = "320px"),
                        type = 6, color = "#2C5F8A", size = 0.6),
            div(class = "fig-caption",
              "Structural missingness (activity metrics on rest days; sleep stages for legacy firmware participants) is expected and not indicative of data quality issues.")
          ),
          br(),
          div(class = "acad-card",
            div(class = "card-label", "Reproducibility"),
            verbatimTextOutput("session_info")
          )
        )
      )
    )
  )
)

# ==============================================================================
# SERVER
# ==============================================================================

server <- function(input, output, session) {

  # ── Reactive: overview-filtered data ────────────────────────────────────────
  df_ov <- reactive({
    d <- garmin %>%
      filter(calendar_date >= input$ov_dates[1],
             calendar_date <= input$ov_dates[2],
             Gender %in% input$ov_gender)
    if (input$ov_cohort != "All")
      d <- d %>% filter(analysis_cohort == input$ov_cohort)
    d
  })

  # ── KPI outputs ─────────────────────────────────────────────────────────────
  output$kpi_n      <- renderText({ n_distinct(df_ov()$User_id) })
  output$kpi_days   <- renderText({ format(nrow(df_ov()), big.mark = ",") })
  output$kpi_tsd    <- renderText({
    paste0(round(mean(df_ov()$TSD, na.rm = TRUE), 1), " h")
  })
  output$kpi_rhr    <- renderText({
    v <- round(mean(df_ov()$RHR_dev_7d, na.rm = TRUE), 2)
    paste0(ifelse(v > 0, "+", ""), v, " bpm")
  })
  output$kpi_actpct <- renderText({
    paste0(round(100 * mean(df_ov()$activity_day, na.rm = TRUE), 0), "%")
  })

  # ── Overview stats ───────────────────────────────────────────────────────────
  output$ov_stats <- renderPrint({
    d <- df_ov()
    cat("Records:", nrow(d), "\n")
    cat("Range:  ", format(min(d$calendar_date)), "to", format(max(d$calendar_date)), "\n\n")
    cat("Steps/day:\n")
    cat("  Median:", round(median(d$DailyTotalSteps, na.rm = TRUE) / 1000, 1), "k\n")
    cat("  Max:   ", round(max(d$DailyTotalSteps, na.rm = TRUE) / 1000, 1), "k\n\n")
    cat("HR (bpm):\n")
    cat("  Max HR:    ", round(max(d$DailyMaxHeartRate_clean, na.rm = TRUE)), "\n")
    cat("  Resting HR:", round(mean(d$DailyRestingHeartRate_clean, na.rm = TRUE)), "\n\n")
    cat("Sleep (h):\n")
    cat("  Median:", round(median(d$TSD, na.rm = TRUE), 1), "\n")
    cat("  SD:    ", round(sd(d$TSD, na.rm = TRUE), 1), "\n\n")
    cat("VO2max (ml/kg/min):\n")
    cat("  Mean:", round(mean(d$VO2max_imputed_final, na.rm = TRUE), 1), "\n")
  })

  # ── Overview Fig 1: recovery donut ──────────────────────────────────────────
  output$ov_recovery_donut <- renderPlotly({
    d <- df_ov() %>% filter(!is.na(RecoveryLevel)) %>% count(RecoveryLevel)
    cols <- c("Excellent" = COL_PRIMARY, "Good" = COL_GOOD,
              "Moderate"  = COL_WARN,    "Poor" = COL_DANGER)
    plot_ly(d, labels = ~RecoveryLevel, values = ~n, type = "pie",
            marker = list(colors = cols[as.character(d$RecoveryLevel)],
                          line   = list(color = "#FAFAF8", width = 2)),
            textinfo  = "label+percent",
            textfont  = list(size = 11, family = "Lora, Georgia, serif"),
            hole = 0.42) %>%
      layout(showlegend = TRUE,
             font = list(family = "Lora, Georgia, serif", size = 11),
             paper_bgcolor = "#FAFAF8", plot_bgcolor = "#FAFAF8",
             legend = list(font = list(size = 10), bgcolor = "rgba(250,250,248,0.9)",
                           bordercolor = "#DDD9D0", borderwidth = 1),
             margin = list(l = 10, r = 10, t = 10, b = 10)) %>%
      config(displayModeBar = FALSE)
  })

  # ── Overview Fig 2: sleep histogram ─────────────────────────────────────────
  output$ov_sleep_hist <- renderPlotly({
    d <- df_ov() %>% filter(!is.na(SleepQuality_pct)) %>%
      mutate(Cat = case_when(
        SleepQuality_pct >= 56 ~ "Rebound",
        SleepQuality_pct >= 48 ~ "Excellent",
        SleepQuality_pct >= 38 ~ "Normal",
        SleepQuality_pct >= 30 ~ "Fair",
        TRUE ~ "Poor"
      ),
      Cat = factor(Cat, levels = c("Poor","Fair","Normal","Excellent","Rebound")))
    cols <- c("Poor" = COL_DANGER, "Fair" = COL_WARN, "Normal" = COL_NEUTRAL,
              "Excellent" = COL_GOOD, "Rebound" = COL_PRIMARY)
    plot_ly(d, x = ~SleepQuality_pct, type = "histogram",
            color = ~Cat, colors = cols, nbinsx = 35,
            marker = list(line = list(width = 0.5, color = "#FAFAF8"))) %>%
      acad_layout("Sleep quality (%)", "Count")
  })

  # ── Overview Fig 3: timeline ─────────────────────────────────────────────────
  output$ov_timeline <- renderPlotly({
    d <- df_ov() %>%
      group_by(calendar_date) %>%
      summarise(steps    = mean(DailyTotalSteps, na.rm = TRUE),
                nxt_rec  = mean(NextDayRecovery,  na.rm = TRUE),
                .groups  = "drop")
    plot_ly(d, x = ~calendar_date) %>%
      add_bars(y = ~steps, name = "Daily steps (t)",
               marker = list(color = "rgba(107,114,128,0.22)",
                             line  = list(color = "rgba(107,114,128,0.35)", width = 0.4)),
               yaxis = "y2") %>%
      add_lines(y = ~nxt_rec, name = "Next-day recovery (t+1)",
                line = list(color = COL_PRIMARY, width = 2.2)) %>%
      layout(
        font = list(family = "Lora, Georgia, serif", size = 12),
        paper_bgcolor = "#FAFAF8", plot_bgcolor = "#FAFAF8",
        xaxis  = list(title = "", showgrid = TRUE, gridcolor = "#E8E4DE",
                      linecolor = "#CCCCCC", mirror = TRUE),
        yaxis  = list(title = "Next-day recovery score", showgrid = TRUE,
                      gridcolor = "#E8E4DE", zeroline = TRUE,
                      zerolinecolor = "#CCCCCC", linecolor = "#CCCCCC", mirror = TRUE),
        yaxis2 = list(title = "Daily steps", overlaying = "y", side = "right",
                      showgrid = FALSE, linecolor = "#CCCCCC"),
        hovermode = "x unified",
        legend = list(orientation = "h", y = 1.06, x = 0,
                      bgcolor = "rgba(250,250,248,0.9)",
                      bordercolor = "#DDD9D0", borderwidth = 1, font = list(size = 11)),
        margin = list(l = 55, r = 55, t = 20, b = 45)
      ) %>% config(displayModeBar = FALSE)
  })

  # ── Sleep Fig 4: quality vs recovery ────────────────────────────────────────
  rec_ylim <- range(garmin$RecoveryScore, na.rm = TRUE)

  output$sl_vs_rec <- renderPlotly({
    d <- garmin %>% filter(!is.na(SleepQuality_pct), !is.na(RecoveryScore), TSD <= 12)
    d <- slice_sample(d, n = min(1000L, nrow(d)))
    lo  <- loess(RecoveryScore ~ SleepQuality_pct, data = d, span = 1.5)
    d2  <- d %>% arrange(SleepQuality_pct) %>%
      mutate(.fit = fitted(lo)[order(SleepQuality_pct)])
    plot_ly(d, x = ~SleepQuality_pct, y = ~RecoveryScore, type = "scatter", mode = "markers",
            marker = list(size = 5, color = COL_PRIMARY, opacity = 0.2,
                          line = list(color = "rgba(44,95,138,0.35)", width = 0.4)),
            text = ~paste("Sleep quality:", round(SleepQuality_pct, 1),
                          "%<br>Recovery:", round(RecoveryScore, 1)),
            hoverinfo = "text") %>%
      add_lines(data = d2, x = ~SleepQuality_pct, y = ~.fit,
                line = list(color = COL_SECONDARY, width = 2.5), name = "LOESS") %>%
      acad_layout("Sleep quality (%)", "Recovery score") %>%
      layout(yaxis = list(range = rec_ylim), showlegend = FALSE)
  })

  # ── Sleep Fig 5: TSD vs recovery ────────────────────────────────────────────
  output$tsd_vs_rec <- renderPlotly({
    d <- garmin %>% filter(!is.na(TSD), !is.na(RecoveryScore), TSD <= 12)
    d <- slice_sample(d, n = min(1000L, nrow(d)))
    lo  <- loess(RecoveryScore ~ TSD, data = d, span = 1.5)
    d2  <- d %>% arrange(TSD) %>% mutate(.fit = fitted(lo)[order(TSD)])
    plot_ly(d, x = ~TSD, y = ~RecoveryScore, type = "scatter", mode = "markers",
            marker = list(size = 5, color = COL_PRIMARY, opacity = 0.2,
                          line = list(color = "rgba(44,95,138,0.35)", width = 0.4)),
            text = ~paste("TSD:", round(TSD, 1), "h<br>Recovery:", round(RecoveryScore, 1)),
            hoverinfo = "text") %>%
      add_lines(data = d2, x = ~TSD, y = ~.fit,
                line = list(color = COL_SECONDARY, width = 2.5), name = "LOESS") %>%
      acad_layout("Sleep duration (h)", "Recovery score") %>%
      layout(yaxis = list(range = rec_ylim), showlegend = FALSE)
  })

  # ── Sleep Fig 6: weekday architecture ───────────────────────────────────────
  output$sl_weekday <- renderPlotly({
    d <- garmin %>%
      filter(!is.na(TSD), !is.na(SleepQuality_pct)) %>%
      group_by(Weekday) %>%
      summarise(dur  = mean(TSD, na.rm = TRUE),
                qual = mean(SleepQuality_pct, na.rm = TRUE), .groups = "drop")
    plot_ly(d) %>%
      add_bars(x = ~Weekday, y = ~dur, name = "Duration (h)",
               marker = list(color = COL_PRIMARY, opacity = 0.8,
                             line = list(color = "#FAFAF8", width = 0.5))) %>%
      add_lines(x = ~Weekday, y = ~qual / 10, name = "Quality (÷10)", yaxis = "y2",
                line   = list(color = COL_SECONDARY, width = 2.5),
                marker = list(size = 7, color = COL_SECONDARY)) %>%
      layout(
        font = list(family = "Lora, Georgia, serif", size = 12),
        paper_bgcolor = "#FAFAF8", plot_bgcolor = "#FAFAF8",
        xaxis  = list(title = "", showgrid = FALSE, linecolor = "#CCCCCC", mirror = TRUE),
        yaxis  = list(title = "Sleep duration (h)", showgrid = TRUE,
                      gridcolor = "#E8E4DE", linecolor = "#CCCCCC", mirror = TRUE),
        yaxis2 = list(title = "Sleep quality (scaled)", overlaying = "y", side = "right",
                      showgrid = FALSE, linecolor = "#CCCCCC"),
        legend = list(orientation = "h", y = 1.06, bgcolor = "rgba(250,250,248,0.9)",
                      bordercolor = "#DDD9D0", borderwidth = 1, font = list(size = 11)),
        margin = list(l = 55, r = 55, t = 20, b = 45)
      ) %>% config(displayModeBar = FALSE)
  })

  # ── Sleep Fig 7: SE violin by cohort ─────────────────────────────────────────
  output$se_violin <- renderPlotly({
    d <- garmin %>% filter(!is.na(SE), !is.na(analysis_cohort))
    plot_ly(d, x = ~analysis_cohort, y = ~SE, type = "violin",
            color = ~analysis_cohort,
            colors = c("full" = COL_PRIMARY, "no_sleep_stages" = COL_SECONDARY),
            box = list(visible = TRUE, width = 0.08),
            meanline = list(visible = TRUE, color = "#1A1A1A"),
            points = "jitter", jitter = 0.3, pointpos = 0,
            marker = list(size = 3, opacity = 0.2), spanmode = "hard") %>%
      acad_layout("Analysis cohort", "Sleep efficiency (ratio)") %>%
      layout(showlegend = FALSE)
  })

  # ── Sleep Table 1 ────────────────────────────────────────────────────────────
  output$sl_stats_tbl <- renderDT({
    d <- garmin %>%
      group_by(User_id) %>%
      arrange(calendar_date) %>%
      mutate(PrevDaySteps = lag(DailyTotalSteps, 1)) %>%
      ungroup() %>%
      filter(!is.na(SleepQualityLevel))
    d %>%
      group_by(SleepQualityLevel, .drop = FALSE) %>%
      summarise(`N (days)`     = n(),
                `TSD (h)`      = round(mean(TSD,           na.rm = TRUE), 1),
                `Recovery`     = round(mean(RecoveryScore,  na.rm = TRUE), 2),
                `Prev. steps`  = round(mean(PrevDaySteps,   na.rm = TRUE), 0),
                `SE`           = round(mean(SE,             na.rm = TRUE), 2),
                .groups = "drop") %>%
      arrange(SleepQualityLevel) %>%
      datatable(rownames = FALSE,
                options = list(dom = "t", pageLength = 10, ordering = FALSE),
                class = "compact stripe")
  })

  # ── Training Fig 8: TV vs next-day recovery ──────────────────────────────────
  output$tv_vs_nextrec <- renderPlotly({
    d <- garmin %>% filter(!is.na(TV), !is.na(NextDayRecovery), TV <= 50)
    d <- slice_sample(d, n = min(1500L, nrow(d)))
    lo  <- loess(NextDayRecovery ~ TV, data = d, span = 1.0)
    d2  <- d %>% arrange(TV) %>% mutate(.fit = fitted(lo)[order(TV)])
    plot_ly(d, x = ~TV, y = ~NextDayRecovery, type = "scattergl", mode = "markers",
            marker = list(size = 4, color = COL_PRIMARY, opacity = 0.14,
                          line = list(width = 0)),
            text = ~paste("Distance:", round(TV, 1),
                          "km<br>Recovery(t+1):", round(NextDayRecovery, 1)),
            hoverinfo = "text") %>%
      add_lines(data = d2, x = ~TV, y = ~.fit,
                line = list(color = COL_SECONDARY, width = 2.5)) %>%
      acad_layout("Training distance (km)", "Next-day recovery score") %>%
      layout(xaxis = list(range = c(0, 50)), showlegend = FALSE)
  })

  # ── Training Fig 9: recovery by intensity ───────────────────────────────────
  output$rec_by_intensity <- renderPlotly({
    d <- garmin %>%
      filter(!is.na(SL_Intensity), !is.na(NextDayRecovery)) %>%
      group_by(SL_Intensity) %>%
      summarise(med = median(NextDayRecovery, na.rm = TRUE),
                q25 = quantile(NextDayRecovery, 0.25, na.rm = TRUE),
                q75 = quantile(NextDayRecovery, 0.75, na.rm = TRUE),
                .groups = "drop")
    p <- ggplot(d, aes(x = as.numeric(SL_Intensity), y = med)) +
      geom_ribbon(aes(ymin = q25, ymax = q75), alpha = 0.18, fill = COL_PRIMARY) +
      geom_line(linewidth = 1.4, colour = COL_PRIMARY) +
      geom_point(size = 4, colour = COL_PRIMARY) +
      scale_x_continuous(breaks = 1:4, labels = levels(d$SL_Intensity)) +
      labs(x = "Session load intensity", y = "Median next-day recovery (IQR)") +
      theme_minimal(base_family = "serif") +
      theme(panel.grid.minor = element_blank(),
            panel.grid.major = element_line(colour = "#E8E4DE"),
            axis.line        = element_line(colour = "#CCCCCC"))
    ggplotly(p) %>%
      layout(paper_bgcolor = "#FAFAF8", plot_bgcolor = "#FAFAF8",
             font = list(family = "Lora, Georgia, serif", size = 12)) %>%
      config(displayModeBar = FALSE)
  })

  # ── Training Fig 10: lag bar chart ───────────────────────────────────────────
  output$lag_bars <- renderPlotly({
    pairs <- list(
      list(x = "SessionLoad", y = "TSD",          label = "Training Load → Sleep"),
      list(x = "SessionLoad", y = "RecoveryScore", label = "Training Load → Recovery"),
      list(x = "TSD",         y = "RecoveryScore", label = "Sleep → Recovery")
    )
    lags <- 0:3
    lag_cols <- list(
      SessionLoad = c("SessionLoad","SessionLoad_lag1","SessionLoad_lag2","SessionLoad_lag3"),
      TSD         = c("TSD","TSD_lag1","TSD_lag2","TSD_lag3")
    )
    res <- lapply(pairs, function(pr) {
      lapply(seq_along(lags), function(i) {
        xcol <- lag_cols[[pr$x]][i]
        if (!xcol %in% names(garmin)) return(NULL)
        x <- garmin[[xcol]]; y <- garmin[[pr$y]]
        ok <- complete.cases(x, y)
        if (sum(ok) < 10) return(NULL)
        r <- cor(x[ok], y[ok], method = "spearman")
        data.frame(Pair = pr$label, Lag = lags[i], r = r)
      }) %>% bind_rows()
    }) %>% bind_rows()

    plot_ly(res, x = ~factor(Lag), y = ~r, color = ~Pair,
            colors = c("Training Load → Sleep"    = COL_PRIMARY,
                       "Training Load → Recovery" = COL_SECONDARY,
                       "Sleep → Recovery"         = COL_GOOD),
            type = "bar",
            text = ~paste0("ρ = ", round(r, 3)), hoverinfo = "x+text",
            marker = list(opacity = 0.85,
                          line = list(color = "#FAFAF8", width = 0.5))) %>%
