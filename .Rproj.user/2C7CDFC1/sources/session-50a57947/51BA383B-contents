    plot_ly() %>%
      add_surface(x = ~xseq, y = ~yseq, z = ~z_mat,
                  colorscale = DIVPAL, opacity = 0.80, showscale = TRUE,
                  colorbar = list(title = "Predicted\nrecovery", len = 0.55,
                                  tickfont = list(family = "Lora, serif"))) %>%
      add_markers(data = d, x = ~SleepQuality_pct, y = ~DailyTotalSteps,
                  z = ~RecoveryScore,
                  marker = list(size = ~pt_size, color = ~RecoveryScore,
                                colorscale = DIVPAL, showscale = FALSE,
                                opacity = 0.6,
                                line = list(color = "white", width = 0.6)),
                  text = ~paste0("Sleep quality: ", round(SleepQuality_pct, 1), "%<br>",
                                 "Steps: ", round(DailyTotalSteps), "<br>",
                                 "Recovery: ", round(RecoveryScore, 1), "<br>",
                                 "Intensity: ", SL_Intensity),
                  hoverinfo = "text") %>%
      layout(
        scene = list(
          xaxis = list(title = "Sleep quality (%)", gridcolor = "#E8E4DE",
                       tickfont = list(family = "Lora, serif", size = 9)),
          yaxis = list(title = "Daily steps", gridcolor = "#E8E4DE",
                       tickfont = list(family = "Lora, serif", size = 9)),
          zaxis = list(title = "Recovery score", gridcolor = "#E8E4DE",
                       tickfont = list(family = "Lora, serif", size = 9)),
          bgcolor = "#FAFAF8",
          camera  = list(eye = list(x = 1.8, y = -1.8, z = 1.2))
        ),
        font = list(family = "Lora, Georgia, serif", size = 11),
        paper_bgcolor = "#FAFAF8"
      ) %>% config(displayModeBar = FALSE)
  })

  # ── Methods: variable dictionary ─────────────────────────────────────────────
  output$dict_tbl <- renderDT({
    tribble(
      ~Column, ~Group, ~`Missing %`, ~Description,
      "RHR_dev_7d",       "Recovery",   "4.3",  "★ PRIMARY RECOVERY METRIC. Deviation of RHR from participant's own 7-day rolling mean. Computed in-app. Positive = under-recovered.",
      "RecoveryScore",    "Recovery",   "4.3",  "= −RHR_dev_7d. Positive = well-recovered.",
      "SessionLoad",      "Training",   "48.1", "★ AvgHR × DurationMinutes. Primary training load proxy. NA on rest days (structural).",
      "RelativeIntensity","Training",   "48.1", "AvgHR / MaxHR. Proportion of HR reserve used. Comparable across participants.",
      "TSD",              "Sleep",      "17.4", "★ Total Sleep Duration (h). Primary sleep outcome. Right-skewed — use median.",
      "SE",               "Sleep",      "17.5", "★ Sleep Efficiency = TSD / TIB. ⚠ SE = 1.0 is a device floor, not perfect sleep.",
      "SF",               "Sleep",      "18.7", "Sleep Fragmentation = AwakeSeconds / TotalSleepSeconds. Higher = more disrupted.",
      "REMSleepProp_final","Sleep",     "38.2", "★ REM proportion (recalculated & validated). Use this, not REMSleepProp.",
      "SleepQuality_pct", "Sleep",      "38.2", "Derived: (Deep + REM) / Total × 100. Restorative sleep index.",
      "VO2max_imputed_final","Fitness", "2.6",  "★ VO2max (ml/kg/min) with LOCF imputation (gaps ≤ 28 days).",
      "DailyBodyBattery.chargedValue","Recovery","17.0","Supplementary only. P008 = 0% coverage; P009/P010 = 18–24% missing.",
      "DailyTotalSteps",  "Activity",   "4.4",  "Total daily step count.",
      "TV",               "Training",   "47.2", "Training volume = session distance (km). 0 for gym sessions; NA on rest days.",
      "HR_range",         "HR",         "3.3",  "DailyMaxHR − DailyMinHR. Proxy for autonomic load range.",
      "analysis_cohort",  "Cohort",     "0.0",  "'full' = 9,700 rows with all sleep metrics. 'no_sleep_stages' = P006/P013/P015."
    ) %>%
      datatable(filter = "top", rownames = FALSE,
                options = list(pageLength = 15, dom = "ftp"),
                class = "compact stripe") %>%
      formatStyle("Missing %",
        backgroundColor = styleInterval(c(5, 20),
                                        c("#DCFCE7","#FEF9C3","#FEE2E2")),
        fontWeight = "bold")
  })

  # ── Methods: cohort table ─────────────────────────────────────────────────────
  output$cohort_tbl <- renderDT({
    garmin %>%
      group_by(User_id) %>%
      summarise(
        Age            = first(Age),
        Sex            = first(Sex),
        `Total days`   = n(),
        Cohort         = first(analysis_cohort),
        `TSD miss %`   = round(100 * mean(is.na(TSD)), 1),
        `BB miss %`    = round(100 * mean(is.na(DailyBodyBattery.chargedValue)), 1),
        `Stage miss %` = round(100 * mean(is.na(REMSleepProp_final)), 1),
        .groups = "drop"
      ) %>%
      datatable(rownames = FALSE, options = list(dom = "t"),
                class = "compact stripe") %>%
      formatStyle("Cohort",
        backgroundColor = styleEqual(c("full","no_sleep_stages"),
                                     c("#DCFCE7","#FEF9C3")))
  })

  # ── Methods: missing data plot ───────────────────────────────────────────────
  output$missing_plot <- renderPlotly({
    n_tot <- nrow(garmin)
    d <- garmin %>%
      summarise(across(everything(), ~ 100 * mean(is.na(.)) )) %>%
      pivot_longer(everything(), names_to = "variable", values_to = "pct") %>%
      filter(pct > 0) %>%
      arrange(desc(pct))
    plot_ly(d, x = ~pct, y = ~reorder(variable, pct),
            type = "bar", orientation = "h",
            marker = list(
              color = ~ifelse(pct > 50, COL_DANGER,
                        ifelse(pct > 20, COL_WARN, COL_PRIMARY)),
              opacity = 0.82,
              line = list(color = "#FAFAF8", width = 0.3)),
            text = ~paste0(round(pct, 1), "%"),
            textposition = "outside",
            textfont = list(size = 9.5, family = "Lora, serif")) %>%
      acad_layout("% missing", "") %>%
      layout(xaxis  = list(range = c(0, 108)),
             margin = list(l = 170, r = 60, t = 20, b = 45))
  })

  # ── Methods: session info ─────────────────────────────────────────────────────
  output$session_info <- renderPrint({ sessionInfo() })
}

