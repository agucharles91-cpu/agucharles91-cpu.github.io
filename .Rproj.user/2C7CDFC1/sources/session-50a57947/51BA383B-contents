garmin_raw <- read_csv("data/garmin_merged_14p.csv",
                       na = c("NA","","N/A"), show_col_types = FALSE)

garmin <- garmin_raw %>%
  arrange(User_id, calendar_date) %>%
  mutate(calendar_date = as.Date(calendar_date)) %>%

  # ── Primary recovery metric: RHR deviation from 7-day rolling personal mean
  group_by(User_id) %>%
  arrange(calendar_date) %>%
  mutate(
    rhr_roll7  = rollapply(DailyRestingHeartRate_clean, width = 7,
                           FUN = mean, na.rm = TRUE, fill = NA, align = "right"),
    RHR_dev_7d = DailyRestingHeartRate_clean - rhr_roll7,
    # Recovery score: positive = well-recovered (flip sign of RHR deviation)
    RecoveryScore = -RHR_dev_7d,

    # Lagged variables (within participant, by date order)
    SessionLoad_lag1 = lag(SessionLoad, 1),
    SessionLoad_lag2 = lag(SessionLoad, 2),
    SessionLoad_lag3 = lag(SessionLoad, 3),
    TSD_lag1         = lag(TSD,         1),
    TSD_lag2         = lag(TSD,         2),
    TSD_lag3         = lag(TSD,         3),
    SE_lag1          = lag(SE,          1),
    RecoveryScore_lag1 = lag(RecoveryScore, 1),
    NextDayRecovery  = lead(RecoveryScore, 1)
  ) %>%
  ungroup() %>%

  mutate(
    # Sleep quality index: restorative sleep proportion
    SleepQuality_pct = (DeepSleepProp + REMSleepProp_final) * 100,
    SleepQualityLevel = case_when(
      SleepQuality_pct >= 56 ~ "Rebound",
      SleepQuality_pct >= 48 ~ "Excellent",
      SleepQuality_pct >= 38 ~ "Normal",
      SleepQuality_pct >= 30 ~ "Fair",
      !is.na(SleepQuality_pct) ~ "Poor",
      TRUE ~ NA_character_
    ),
    SleepQualityLevel = factor(SleepQualityLevel,
                               levels = c("Rebound","Excellent","Normal","Fair","Poor")),

    # Recovery categories by population tertile
    RecoveryLevel = case_when(
      RecoveryScore > quantile(RecoveryScore, 0.80, na.rm = TRUE) ~ "Excellent",
      RecoveryScore > quantile(RecoveryScore, 0.60, na.rm = TRUE) ~ "Good",
      RecoveryScore > quantile(RecoveryScore, 0.35, na.rm = TRUE) ~ "Moderate",
      !is.na(RecoveryScore) ~ "Poor",
      TRUE ~ NA_character_
    ),
    RecoveryLevel = factor(RecoveryLevel,
                           levels = c("Excellent","Good","Moderate","Poor")),

    # Session load intensity (terciles on active days)
    SL_Intensity = {
      sl_q <- quantile(SessionLoad[SessionLoad > 0 & !is.na(SessionLoad)],
                       probs = c(0.33, 0.67), na.rm = TRUE)
      case_when(
        is.na(SessionLoad) | SessionLoad == 0 ~ "Rest Day",
        SessionLoad <= sl_q[1]                ~ "Light",
        SessionLoad <= sl_q[2]                ~ "Moderate",
        TRUE                                  ~ "High"
      )
    },
    SL_Intensity = factor(SL_Intensity,
                          levels = c("Rest Day","Light","Moderate","High")),

    Gender   = ifelse(Sex == "M", "Male", "Female"),
    Gender   = factor(Gender, levels = c("Male","Female")),
    Weekday  = wday(calendar_date, label = TRUE, abbr = FALSE, week_start = 1),
    IsWeekend = ifelse(wday(calendar_date) %in% c(1, 7), "Weekend", "Weekday"),

    # Activity grouping for labels
    ActivityGroup = case_when(
      ActivitiesType %in% c("running","track_running","trail_running",
                            "treadmill_running")                      ~ "Running",
      ActivitiesType %in% c("cycling","indoor_cycling","e_bike_fitness") ~ "Cycling",
      ActivitiesType %in% c("strength_training","hiit")               ~ "Strength / HIIT",
      ActivitiesType %in% c("lap_swimming","open_water_swimming",
                            "indoor_rowing")                          ~ "Swim / Row",
      ActivitiesType %in% c("yoga","pilates","meditation","breathwork") ~ "Mind–Body",
      is.na(ActivitiesType)                                           ~ "Rest Day",
      TRUE                                                            ~ "Other"
    ),
    ActivityGroup = factor(ActivityGroup,
      levels = c("Running","Cycling","Strength / HIIT","Swim / Row",
                 "Mind–Body","Other","Rest Day"))
  )

