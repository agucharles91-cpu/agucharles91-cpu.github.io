    ct <- summary(m)$coefficients
    ci <- confint(m)
    interp_term <- function(term, label) {
      if (!term %in% rownames(ct)) return(NULL)
      est <- round(ct[term, 1], 4)
      lo  <- round(ci[term, 1], 4)
      hi  <- round(ci[term, 2], 4)
      pv  <- ct[term, 4]
      sig <- ifelse(pv < 0.05, "statistically significant (p < 0.05)",
                   "not statistically significant (p ≥ 0.05)")
      tags$p(
        tags$b(label, ": "),
        paste0("A one-unit increase is associated with a ",
               abs(est), " ", ifelse(est > 0, "increase", "decrease"),
               " in next-day recovery score (95% CI: [", lo, ", ", hi, "]",
               ", p ", ifelse(pv < 0.001, "< 0.001", round(pv, 3)),
               "). This association is ", sig, ".")
      )
    }
    div(
      style = "background:#F0EDE6; border-left:4px solid #2C5F8A; border-radius:0 3px 3px 0;
               padding:12px 16px; font-size:12.5px; color:#444; font-family:'Lora',serif;",
