          "Count of athlete-days in each intensity category. Rest days (SL = 0 or missing) shown separately."
        )),
        column(6, fig_card(
          "Figure 20 — Training volume distribution",
          "eda_tv_hist", "270px",
          "Distribution of daily training distance (km). Rest days (TV = 0) excluded. Upper bound at 99th percentile."
        ))
      ),
      fig_card(
        "Figure 21 — Missing data audit",
        "eda_missing", "420px",
        "Percentage of missing values per column across the filtered dataset. Structural missingness (activity metrics absent on rest days; sleep metrics absent on nights without a recorded sleep session) is expected and not indicative of data quality issues."
      )
    )
  )
)

# ==============================================================================
# SERVER — unchanged from prior version
# ==============================================================================
server <- function(input, output, session) {

  filtered_overview <- reactive({
    garmin %>%
      filter(
        calendar_date >= input$overview_dates[1],
        calendar_date <= input$overview_dates[2],
        Gender %in% input$overview_gender
      )
  })

  output$overview_stats <- renderPrint({
    d <- filtered_overview()
    cat("Records:", nrow(d), "\n")
    cat("Range:  ", format(min(d$calendar_date)), "to", format(max(d$calendar_date)), "\n\n")
    if ("DailyActivityLoad" %in% names(d)) {
      cat("Steps/day:\n")
      cat("  Mean:", round(mean(d$DailyActivityLoad, na.rm=TRUE)/1000,1), "k\n")
      cat("  Min: ", round(min(d$DailyActivityLoad,  na.rm=TRUE)/1000,1), "k\n")
      cat("  Max: ", round(max(d$DailyActivityLoad,  na.rm=TRUE)/1000,1), "k\n\n")
    }
    if (all(c("DailyMaxHeartRate_clean","DailyRestingHeartRate_clean") %in% names(d))) {
      cat("HR (bpm):\n")
      cat("  Max HR:    ", round(max(d$DailyMaxHeartRate_clean, na.rm=TRUE)), "\n")
      cat("  Resting HR:", round(mean(d$DailyRestingHeartRate_clean, na.rm=TRUE)), "\n\n")
    }
    if ("TV" %in% names(d)) {
      cat("Distance (km):\n")
      cat("  Mean:", round(median(d$TV, na.rm=TRUE), 2), "\n")
      cat("  Max: ", round(max(d$TV, na.rm=TRUE), 2), "\n\n")
    }
    if ("TSD" %in% names(d)) {
      cat("Sleep (h):\n")
      cat("  Mean:", round(median(d$TSD, na.rm=TRUE), 1), "\n")
      cat("  Min: ", round(min(d$TSD,  na.rm=TRUE), 1), "\n")
      cat("  Max: ", round(max(d$TSD,  na.rm=TRUE), 1), "\n\n")
    }
    if ("ActivitiesVO2MaxValue" %in% names(d))
      cat("VO2max (ml/kg/min):", round(mean(d$ActivitiesVO2MaxValue, na.rm=TRUE), 1), "\n")
  })

  output$n_athletes       <- renderText({ n_distinct(filtered_overview()$User_id) })
  output$avg_recovery     <- renderText({ round(mean(filtered_overview()$RecoveryScore, na.rm=TRUE), 2) })
  output$avg_sleep_quality <- renderText({ paste0(round(mean(filtered_overview()$SleepQuality_pct, na.rm=TRUE), 0), "%") })
  output$avg_steps        <- renderText({ paste0(round(mean(filtered_overview()$DailyActivityLoad, na.rm=TRUE)/1000, 1), "k") })

  # ── Overview plots ──────────────────────────────────────────────────────────

  output$recovery_dist <- renderPlotly({
    d <- filtered_overview() %>% filter(!is.na(RecoveryLevel)) %>% count(RecoveryLevel)
    colors <- c("Excellent"="#2C5F8A","Good"="#3A6B4A","Moderate"="#B07D2C","Poor"="#8A2C2C")
    plot_ly(d, labels=~RecoveryLevel, values=~n, type="pie",
            marker=list(colors=colors[d$RecoveryLevel],
                        line=list(color="#FAFAF8", width=2)),
            textinfo="label+percent", textfont=list(size=12, family="Lora, Georgia, serif"),
            hole=0.42) %>%
      layout(showlegend=TRUE,
             font=list(family="Lora, Georgia, serif", size=12),
             paper_bgcolor="#FAFAF8", plot_bgcolor="#FAFAF8",
             legend=list(font=list(size=11), bgcolor="rgba(250,250,248,0.9)",
                         bordercolor="#DDD9D0", borderwidth=1),
             margin=list(l=10,r=10,t=10,b=10)) %>%
      config(displayModeBar=FALSE)
  })

  output$sleep_quality_dist <- renderPlotly({
    d <- filtered_overview() %>%
      filter(!is.na(SleepQuality_pct)) %>%
      mutate(SleepCategory = case_when(
        SleepQuality_pct >= 55 ~ "Rebound",
        SleepQuality_pct >= 45 ~ "Excellent",
        SleepQuality_pct >= 35 ~ "Normal",
        SleepQuality_pct >= 30 ~ "Fair",
        TRUE ~ "Poor"
      ),
      SleepCategory = factor(SleepCategory, levels=c("Poor","Fair","Normal","Excellent","Rebound")))
    colors <- c("Poor"="#8A2C2C","Fair"="#B07D2C","Normal"="#6B7280","Excellent"="#3A6B4A","Rebound"="#2C5F8A")
    plot_ly(d, x=~SleepQuality_pct, type="histogram", color=~SleepCategory, colors=colors,
            nbinsx=30, marker=list(line=list(width=0.5, color="#FAFAF8"))) %>%
      acad_layout("Sleep Quality (%)", "Count")
  })

  output$recovery_timeline <- renderPlotly({
    d <- filtered_overview() %>%
      arrange(calendar_date) %>%
      group_by(calendar_date) %>%
      summarise(DailyLoad=mean(DailyActivityLoad,na.rm=TRUE), Recovery=mean(RecoveryScore,na.rm=TRUE), .groups="drop") %>%
      mutate(NextDayRecovery=lead(Recovery,1)) %>%
      filter(!is.na(NextDayRecovery))
    if (nrow(d)==0) return(plotly_empty())
    plot_ly(d, x=~calendar_date) %>%
      add_bars(y=~DailyLoad, name="Daily steps (t)",
               marker=list(color="rgba(107,114,128,0.25)", line=list(color="rgba(107,114,128,0.4)",width=0.5)),
               yaxis="y2") %>%
      add_lines(y=~NextDayRecovery, name="Next-day recovery (t+1)",
                line=list(color=COL_PRIMARY, width=2.2)) %>%
      layout(
        font=list(family="Lora, Georgia, serif", size=12),
        paper_bgcolor="#FAFAF8", plot_bgcolor="#FAFAF8",
        xaxis=list(title="", showgrid=TRUE, gridcolor="#E8E4DE", linecolor="#CCCCCC", mirror=TRUE),
        yaxis=list(title="Next-day recovery", showgrid=TRUE, gridcolor="#E8E4DE",
                   zeroline=TRUE, zerolinecolor="#CCCCCC", linecolor="#CCCCCC", mirror=TRUE),
        yaxis2=list(title="Daily steps", overlaying="y", side="right", showgrid=FALSE,
                    linecolor="#CCCCCC", mirror=FALSE),
        hovermode="x unified",
        legend=list(orientation="h", y=1.06, x=0, font=list(size=11),
                    bgcolor="rgba(250,250,248,0.9)", bordercolor="#DDD9D0", borderwidth=1),
        margin=list(l=55, r=55, t=20, b=45)
      ) %>% config(displayModeBar=FALSE)
  })

  # ── Sleep plots ─────────────────────────────────────────────────────────────
  recovery_ylim <- range(garmin$RecoveryScore, na.rm=TRUE)

  output$sleep_duration_vs_recovery <- renderPlotly({
    d <- garmin %>% filter(!is.na(TSD), !is.na(RecoveryScore)) %>% slice_sample(n=min(1000, nrow(.)))
    lo <- loess(RecoveryScore ~ TSD, data=d, span=1.5)
    d2 <- d %>% arrange(TSD) %>% mutate(.fit=fitted(lo)[order(TSD)])
    plot_ly(d, x=~TSD, y=~RecoveryScore, type="scatter", mode="markers",
            marker=list(size=5, color=COL_PRIMARY, opacity=0.22,
                        line=list(color="rgba(44,95,138,0.4)", width=0.5)),
            name="Observations",
            text=~paste("Sleep:",round(TSD,1),"h<br>Recovery:",round(RecoveryScore,1)),
            hoverinfo="text") %>%
      add_lines(data=d2, x=~TSD, y=~.fit,
                line=list(color=COL_SECONDARY, width=2.5), name="LOESS") %>%
      acad_layout("Sleep duration (h)", "Recovery score") %>%
      layout(yaxis=list(range=recovery_ylim), showlegend=FALSE)
  })

  output$sleep_vs_recovery <- renderPlotly({
    d <- garmin %>% filter(!is.na(SleepQuality_pct), !is.na(RecoveryScore), !is.na(TSD), TSD<=12) %>%
      slice_sample(n=min(1000, nrow(.)))
    lo <- loess(RecoveryScore ~ SleepQuality_pct, data=d, span=1.5)
    d2 <- d %>% arrange(SleepQuality_pct) %>% mutate(.fit=fitted(lo)[order(SleepQuality_pct)])
    plot_ly(d, x=~SleepQuality_pct, y=~RecoveryScore, type="scatter", mode="markers",
            marker=list(size=5, color=COL_PRIMARY, opacity=0.22,
                        line=list(color="rgba(44,95,138,0.4)", width=0.5)),
            name="Observations",
            text=~paste("Sleep quality:",round(SleepQuality_pct,1),"%<br>Recovery:",round(RecoveryScore,1)),
            hoverinfo="text") %>%
      add_lines(data=d2, x=~SleepQuality_pct, y=~.fit,
                line=list(color=COL_SECONDARY, width=2.5), name="LOESS") %>%
      acad_layout("Sleep quality (%)", "Recovery score") %>%
      layout(yaxis=list(range=recovery_ylim), showlegend=FALSE)
  })

  output$sleep_by_weekday <- renderPlotly({
    d <- garmin %>% filter(!is.na(TSD), !is.na(SleepQuality_pct)) %>%
      group_by(Weekday) %>%
      summarise(AvgDuration=mean(TSD,na.rm=TRUE), AvgQuality=mean(SleepQuality_pct,na.rm=TRUE), .groups="drop")
    plot_ly(d) %>%
      add_bars(x=~Weekday, y=~AvgDuration, name="Duration (h)",
               marker=list(color=COL_PRIMARY, opacity=0.8, line=list(color="#FAFAF8",width=0.5))) %>%
      add_lines(x=~Weekday, y=~AvgQuality/10, name="Quality (/10)", yaxis="y2",
                line=list(color=COL_SECONDARY, width=2.5),
                marker=list(size=7, color=COL_SECONDARY)) %>%
      layout(
        font=list(family="Lora, Georgia, serif", size=12),
        paper_bgcolor="#FAFAF8", plot_bgcolor="#FAFAF8",
        xaxis=list(title="", showgrid=FALSE, linecolor="#CCCCCC", mirror=TRUE),
        yaxis=list(title="Sleep duration (h)", showgrid=TRUE, gridcolor="#E8E4DE",
                   linecolor="#CCCCCC", mirror=TRUE),
        yaxis2=list(title="Sleep quality (scaled)", overlaying="y", side="right",
                    showgrid=FALSE, linecolor="#CCCCCC"),
        legend=list(orientation="h", y=1.06, bgcolor="rgba(250,250,248,0.9)",
                    bordercolor="#DDD9D0", borderwidth=1, font=list(size=11)),
        margin=list(l=55, r=55, t=20, b=45)
      ) %>% config(displayModeBar=FALSE)
  })

  output$sleep_stats_table <- renderDT({
    req(filtered_overview())
    d <- filtered_overview() %>%
      arrange(User_id, calendar_date) %>%
      group_by(User_id) %>%
      mutate(PrevDaySteps=lag(DailyActivityLoad,1)) %>%
      ungroup() %>%
      filter(!is.na(SleepQualityLevel))
    if (nrow(d)==0) return(datatable(data.frame(Message="No data"), options=list(dom="t"), rownames=FALSE))
    level_order <- c("Rebound","Excellent","Normal","Fair","Poor")
    d %>%
      mutate(SleepQualityLevel=factor(SleepQualityLevel, levels=level_order)) %>%
      group_by(SleepQualityLevel, .drop=FALSE) %>%
      summarise(`N (days)`=n(), `Sleep (h)`=round(mean(TSD,na.rm=TRUE),1),
                `Recovery`=round(mean(RecoveryScore,na.rm=TRUE),2),
                `Prev. steps`=round(mean(PrevDaySteps,na.rm=TRUE),0), .groups="drop") %>%
      arrange(SleepQualityLevel) %>%
      datatable(rownames=FALSE,
                options=list(dom="t", pageLength=10, ordering=FALSE),
                class="compact stripe")
  })

  # ── Training plots ──────────────────────────────────────────────────────────

  output$distance_vs_recovery <- renderPlotly({
    d <- garmin %>%
      filter(!is.na(TV), !is.na(RecoveryScore)) %>%
      group_by(User_id) %>% arrange(calendar_date) %>%
      mutate(NextDayRecovery=lead(RecoveryScore,1)) %>%
      ungroup() %>% filter(!is.na(NextDayRecovery)) %>%
      slice_sample(n=min(1500, nrow(.)))
    lo <- loess(NextDayRecovery ~ TV, data=d, span=1.0)
    d2 <- d %>% arrange(TV) %>% mutate(.fit=fitted(lo)[order(TV)])
    plot_ly(d, x=~TV, y=~NextDayRecovery, type="scattergl", mode="markers",
            marker=list(size=4, color=COL_PRIMARY, opacity=0.14,
                        line=list(width=0)),
            text=~paste("Distance:",round(TV,1),"km<br>Recovery(t+1):",round(NextDayRecovery,1)),
            hoverinfo="text") %>%
      add_lines(data=d2, x=~TV, y=~.fit,
                line=list(color=COL_SECONDARY, width=2.5), name="LOESS") %>%
      acad_layout("Training distance (km)", "Next-day recovery score") %>%
      layout(xaxis=list(range=c(0,50)), showlegend=FALSE)
  })

  output$recovery_by_intensity <- renderPlotly({
    req(filtered_overview())
    d <- filtered_overview() %>%
      filter(!is.na(SL_Intensity), !is.na(NextDayRecovery)) %>%
      mutate(SL_Intensity=factor(SL_Intensity, levels=c("Rest Day","Light","Moderate","High"), ordered=TRUE)) %>%
      group_by(SL_Intensity) %>%
      summarise(med=median(NextDayRecovery,na.rm=TRUE),
                q25=quantile(NextDayRecovery,.25,na.rm=TRUE),
                q75=quantile(NextDayRecovery,.75,na.rm=TRUE))
    p <- ggplot(d, aes(x=as.numeric(SL_Intensity), y=med)) +
      geom_ribbon(aes(ymin=q25,ymax=q75), alpha=0.18, fill=COL_PRIMARY) +
      geom_line(linewidth=1.4, colour=COL_PRIMARY) +
      geom_point(size=4, colour=COL_PRIMARY) +
      scale_x_continuous(breaks=1:4, labels=levels(d$SL_Intensity)) +
      labs(x="Session load intensity", y="Median next-day recovery (IQR)") +
      theme_minimal(base_family="serif") +
      theme(panel.grid.minor=element_blank(),
            panel.grid.major=element_line(colour="#E8E4DE"),
            axis.line=element_line(colour="#CCCCCC"))
    ggplotly(p) %>%
      layout(paper_bgcolor="#FAFAF8", plot_bgcolor="#FAFAF8",
             font=list(family="Lora, Georgia, serif", size=12)) %>%
      config(displayModeBar=FALSE)
  })

  output$efficiency_vs_distance <- renderPlotly({
    req(filtered_overview())
    d <- filtered_overview() %>%
      filter(!is.na(TV), !is.na(EfficiencyIndex), !is.na(SL_Intensity), TV>0) %>%
      mutate(SL_Intensity=factor(SL_Intensity, levels=c("Light","Moderate","High")))
    req(nrow(d)>=10)
    tv_cap <- quantile(d$TV, .99, na.rm=TRUE)
    d <- filter(d, TV<=tv_cap)
    lo <- loess(EfficiencyIndex~TV, data=d, span=0.9, degree=1, control=loess.control(surface="direct"))
    tv_seq <- seq(min(d$TV), max(d$TV), length.out=200)
    trend_df <- data.frame(TV=tv_seq, EfficiencyIndex=predict(lo, newdata=data.frame(TV=tv_seq)))
    colors <- c("Light"=COL_GOOD,"Moderate"=COL_WARN,"High"=COL_DANGER)
    plot_ly(d, x=~TV, y=~EfficiencyIndex, type="scattergl", mode="markers",
            color=~SL_Intensity, colors=colors,
            marker=list(size=5, opacity=0.45, line=list(width=0)),
            text=~paste0("Distance: ",round(TV,1)," km<br>Efficiency: ",round(EfficiencyIndex,3),"<br>Intensity: ",SL_Intensity),
            hoverinfo="text") %>%
      add_trace(data=trend_df, x=~TV, y=~EfficiencyIndex, type="scatter", mode="lines",
                line=list(color="#1A1A1A", width=2.5), name="LOESS",
                inherit=FALSE, showlegend=FALSE) %>%
      acad_layout("Training distance (km)", "Efficiency index (pace / HR)") %>%
      layout(xaxis=list(range=c(0,tv_cap)), yaxis=list(range=c(0,0.25)),
             legend=list(title=list(text="Intensity"), font=list(size=11),
                         bgcolor="rgba(250,250,248,0.9)", bordercolor="#DDD9D0", borderwidth=1)) %>%
      config(displayModeBar=FALSE)
  })

  output$training_load_dist <- renderPlotly({
    req(filtered_overview())
    d <- filtered_overview() %>% filter(!is.na(SL), SL>0) %>%
      mutate(Weekday=wday(calendar_date, label=TRUE, abbr=FALSE))
    plot_ly(d, x=~Weekday, y=~SL, type="box", color=~Weekday,
            colors=c(COL_PRIMARY,COL_GOOD,COL_WARN,COL_SECONDARY,COL_DANGER,"#6B7280","#8A3A5F"),
            boxmean=TRUE, showlegend=FALSE,
            marker=list(size=3, opacity=0.3),
            line=list(width=1.5)) %>%
      acad_layout("", "Session load (avg HR × duration)") %>%
      layout(yaxis=list(range=c(0,40000))) %>%
      config(displayModeBar=FALSE)
  })

  # ── Sex comparison plots ─────────────────────────────────────────────────────

  output$gender_recovery <- renderPlotly({
    d <- garmin %>% filter(!is.na(RecoveryScore), !is.na(Gender)) %>%
      mutate(Gender=factor(Gender, levels=c("Male","Female")))
    plot_ly(d, x=~Gender, y=~RecoveryScore, type="violin", color=~Gender,
            colors=c("Male"=COL_MALE,"Female"=COL_FEMALE),
            box=list(visible=TRUE, width=0.08),
            meanline=list(visible=TRUE, color="#1A1A1A"),
            points="jitter", jitter=0.25, pointpos=0,
            marker=list(size=3, opacity=0.25), spanmode="hard",
            hoverinfo="y") %>%
      acad_layout("", "Recovery score") %>%
      layout(showlegend=FALSE) %>%
      config(displayModeBar=FALSE)
  })

  output$ttest_recovery <- renderPrint({
    male   <- garmin %>% filter(Gender=="Male")   %>% pull(RecoveryScore) %>% na.omit()
    female <- garmin %>% filter(Gender=="Female") %>% pull(RecoveryScore) %>% na.omit()
    if (length(male)>0 & length(female)>0) {
      t <- t.test(male, female)
      cat("Welch two-sample t-test\n")
      cat(sprintf("Male   M = %.2f (SD = %.2f, n = %d)\n", mean(male), sd(male), length(male)))
      cat(sprintf("Female M = %.2f (SD = %.2f, n = %d)\n", mean(female), sd(female), length(female)))
      cat(sprintf("t(%s) = %.3f, p = %s\n", round(t$parameter,1), t$statistic, format.pval(t$p.value, digits=3)))
      cat(sprintf("95%% CI: [%.3f, %.3f]\n", t$conf.int[1], t$conf.int[2]))
      cat(ifelse(t$p.value<.05, "→ Statistically significant (p < .05)", "→ Not significant (p ≥ .05)"))
    }
  })

  output$gender_sleep <- renderPlotly({
    d <- garmin %>% filter(!is.na(SleepQuality_pct), !is.na(Gender)) %>%
      mutate(Gender=factor(Gender, levels=c("Male","Female")))
    plot_ly(d, x=~Gender, y=~SleepQuality_pct, type="violin", color=~Gender,
            colors=c("Male"=COL_MALE,"Female"=COL_FEMALE),
            box=list(visible=TRUE, width=0.08),
            meanline=list(visible=TRUE, color="#1A1A1A"),
            points="jitter", jitter=0.25, pointpos=0,
            marker=list(size=3, opacity=0.25), spanmode="hard",
            hoverinfo="y") %>%
      acad_layout("", "Sleep quality (%)") %>%
      layout(showlegend=FALSE) %>%
      config(displayModeBar=FALSE)
  })

  output$ttest_sleep <- renderPrint({
    male   <- garmin %>% filter(Gender=="Male")   %>% pull(SleepQuality_pct) %>% na.omit()
    female <- garmin %>% filter(Gender=="Female") %>% pull(SleepQuality_pct) %>% na.omit()
    if (length(male)>0 & length(female)>0) {
      t <- t.test(male, female)
      cat("Welch two-sample t-test\n")
      cat(sprintf("Male   M = %.1f%% (SD = %.1f, n = %d)\n", mean(male), sd(male), length(male)))
      cat(sprintf("Female M = %.1f%% (SD = %.1f, n = %d)\n", mean(female), sd(female), length(female)))
      cat(sprintf("t(%s) = %.3f, p = %s\n", round(t$parameter,1), t$statistic, format.pval(t$p.value, digits=3)))
      cat(sprintf("95%% CI: [%.3f, %.3f]\n", t$conf.int[1], t$conf.int[2]))
      cat(ifelse(t$p.value<.05, "→ Statistically significant (p < .05)", "→ Not significant (p ≥ .05)"))
    }
  })

  output$gender_distance <- renderPlotly({
    d <- garmin %>% filter(!is.na(TV), !is.na(Gender)) %>%
      mutate(Gender=factor(Gender, levels=c("Male","Female")))
    plot_ly(d, x=~Gender, y=~TV, type="violin", color=~Gender,
            colors=c("Male"=COL_MALE,"Female"=COL_FEMALE),
            box=list(visible=TRUE, width=0.08),
            meanline=list(visible=TRUE, color="#1A1A1A"),
            points="jitter", jitter=0.25, pointpos=0,
            marker=list(size=3, opacity=0.25), spanmode="hard",
            hoverinfo="y") %>%
      acad_layout("", "Training distance (km)") %>%
      layout(showlegend=FALSE) %>%
      config(displayModeBar=FALSE)
  })

  output$gender_summary_table <- renderDT({
    long_data <- garmin %>%
      filter(Gender %in% c("Male","Female")) %>%
      group_by(Gender) %>%
      summarise(
        Days = n(),
        `BMI` = round(mean(Weight_kg/((Height_cm/100)^2), na.rm=TRUE), 1),
        `Sleep quality (%)` = round(mean(SleepQuality_pct, na.rm=TRUE), 0),
        `Distance (km)` = round(mean(TV, na.rm=TRUE), 1),
        `Efficiency` = round(mean(EfficiencyIndex, na.rm=TRUE), 3),
        `Sleep duration` = {
          m <- mean(TSD, na.rm=TRUE); paste0(floor(m),"h ", round(60*(m-floor(m)),0),"m")
        }, .groups="drop"
      ) %>%
      mutate(across(-Gender, as.character)) %>%
      pivot_longer(-Gender, names_to="Metric", values_to="Value") %>%
      pivot_wider(names_from=Gender, values_from=Value)
    datatable(long_data,
              options=list(dom="t", pageLength=20, scrollY="300px", scrollX=TRUE),
              rownames=FALSE, class="compact stripe") %>%
      formatStyle(1, fontWeight="bold")
  })

  # ── Relationship plots ──────────────────────────────────────────────────────

  output$recovery_correlations <- renderPlotly({
    req(filtered_overview())
    d <- filtered_overview()
    needed <- c("RecoveryScore","SleepQuality_pct","TSD","TV","DailyActivityLoad","SL")
    avail  <- needed[needed %in% names(d)]
    req(length(avail)>=2)
    cd <- d %>% select(all_of(avail)) %>% drop_na()
    req(nrow(cd)>=10)
    display <- c(RecoveryScore="Recovery", SleepQuality_pct="Sleep quality",
                 TSD="Sleep duration", TV="Distance", DailyActivityLoad="Daily steps", SL="Session load")
    names(cd) <- display[names(cd)]
    cors <- cor(cd)[,"Recovery"]; cors <- cors[names(cors)!="Recovery"]
    df <- data.frame(Variable=names(cors), r=as.numeric(cors)) %>% arrange(r)
    df$Color <- ifelse(df$r>0, COL_GOOD, COL_DANGER)
    plot_ly(df, y=~Variable, x=~r, type="bar", orientation="h",
            marker=list(color=~Color, opacity=0.85,
                        line=list(color="#FAFAF8", width=0.5)),
            text=~paste0("r = ",round(r,3)), textposition="outside",
            textfont=list(size=11, family="Lora, serif"),
            hoverinfo="x+text") %>%
      acad_layout("Pearson r with recovery score", "") %>%
      layout(xaxis=list(range=c(-0.6,0.6), zeroline=TRUE, zerolinecolor="#999",
                        zerolinewidth=1.5),
             margin=list(l=110, r=60, t=20, b=45)) %>%
      config(displayModeBar=FALSE)
  })

  output$correlation_heatmap <- renderPlotly({
    req(filtered_overview())
    d <- filtered_overview()
    possible <- c("RecoveryScore","SleepQuality_pct","TSD","TV","SL","HR_range","EfficiencyIndex")
    avail    <- possible[possible %in% names(d)]
    req(length(avail)>=2)
    cd <- d %>% select(all_of(avail)) %>% drop_na()
    req(nrow(cd)>=10)
    display <- c(RecoveryScore="Recovery", SleepQuality_pct="Sleep quality",
                 TSD="Sleep hrs", TV="Distance", SL="Session load",
                 HR_range="HR range", EfficiencyIndex="Efficiency")
    names(cd) <- display[names(cd)]
    cm <- cor(cd)
    n  <- nrow(cm); nms <- rownames(cm)
    plot_ly(x=nms, y=nms, z=cm, type="heatmap",
            colorscale=DIVPAL, zmid=0, zmin=-1, zmax=1,
            text=round(cm,2),
            hovertemplate="%{x} vs %{y}<br>r = %{z:.2f}<extra></extra>",
            colorbar=list(title="r", len=0.8)) %>%
      add_annotations(x=rep(nms,each=n), y=rep(nms,times=n),
                      text=as.vector(round(cm,2)), showarrow=FALSE,
                      font=list(size=11, family="Lora, Georgia, serif", color="#1A1A1A")) %>%
      layout(font=list(family="Lora, Georgia, serif", size=11),
             paper_bgcolor="#FAFAF8", plot_bgcolor="#FAFAF8",
             xaxis=list(title="", tickangle=-40, linecolor="#CCCCCC", mirror=TRUE),
             yaxis=list(title="", autorange="reversed", linecolor="#CCCCCC", mirror=TRUE),
             margin=list(l=10,r=10,t=10,b=90)) %>%
      config(displayModeBar=FALSE)
  })

  output$three_way_relationship <- renderPlotly({
    d_raw <- garmin %>%
      filter(!is.na(SleepQuality_pct), !is.na(DailyActivityLoad),
             !is.na(RecoveryScore), !is.na(SL_Intensity),
             SleepQuality_pct>=0, SleepQuality_pct<=100,
             DailyActivityLoad>0, DailyActivityLoad<=30000)
    q1<-quantile(d_raw$DailyActivityLoad,.15,na.rm=TRUE)
    q3<-quantile(d_raw$DailyActivityLoad,.85,na.rm=TRUE)
    iqr_val<-q3-q1
    d <- d_raw %>% filter(DailyActivityLoad>=q1-1.5*iqr_val, DailyActivityLoad<=q3+1.5*iqr_val)
    if(nrow(d)<30) return(plotly_empty() %>% layout(title="Insufficient data"))
    d <- d %>% slice_sample(n=min(1000, nrow(.)))
    gam_m <- gam(RecoveryScore~s(SleepQuality_pct,DailyActivityLoad,k=30), data=d)
    x_seq <- seq(min(d$SleepQuality_pct), max(d$SleepQuality_pct), length.out=60)
    y_seq <- seq(min(d$DailyActivityLoad), max(d$DailyActivityLoad), length.out=60)
    grid  <- expand.grid(SleepQuality_pct=x_seq, DailyActivityLoad=y_seq)
    grid$Recovery_hat <- predict(gam_m, newdata=grid)
    z_mat <- matrix(grid$Recovery_hat, nrow=length(x_seq), ncol=length(y_seq))
    size_map <- c("Light"=4,"Moderate"=8,"High"=12)
    d$point_size <- size_map[as.character(d$SL_Intensity)]
    d$point_size[is.na(d$point_size)] <- 4
    plot_ly() %>%
      add_surface(x=~x_seq, y=~y_seq, z=~z_mat,
                  colorscale=list(c(0,"#8A2C2C"),c(0.5,"#F5F5F0"),c(1,"#2C5F8A")),
                  reversescale=FALSE, opacity=0.82, showscale=TRUE,
                  colorbar=list(title="Predicted\nrecovery", len=0.6,
                                tickfont=list(family="Lora, serif")),
                  contours=list(z=list(show=TRUE,usecolormap=TRUE,
                                       project=list(z=TRUE)))) %>%
      add_markers(data=d, x=~SleepQuality_pct, y=~DailyActivityLoad, z=~RecoveryScore,
                  marker=list(size=~point_size,
                              color=~RecoveryScore,
                              colorscale=list(c(0,"#8A2C2C"),c(0.5,"#F5F5F0"),c(1,"#2C5F8A")),
                              showscale=FALSE, opacity=0.65,
                              line=list(color="white",width=0.8)),
                  text=~paste0("Sleep quality: ",round(SleepQuality_pct,1),"%<br>",
                               "Daily steps: ",round(DailyActivityLoad),"<br>",
                               "Recovery: ",round(RecoveryScore,1),"<br>",
                               "Intensity: ",SL_Intensity),
                  hoverinfo="text") %>%
      layout(scene=list(
               xaxis=list(title="Sleep quality (%)", gridcolor="#E8E4DE",
                          tickfont=list(family="Lora, serif", size=10)),
               yaxis=list(title="Daily steps", gridcolor="#E8E4DE",
                          tickfont=list(family="Lora, serif", size=10)),
               zaxis=list(title="Recovery score", gridcolor="#E8E4DE",
                          tickfont=list(family="Lora, serif", size=10)),
               bgcolor="#FAFAF8",
               camera=list(eye=list(x=1.8,y=-1.8,z=1.2))),
             font=list(family="Lora, Georgia, serif", size=12),
             paper_bgcolor="#FAFAF8") %>%
      config(displayModeBar=FALSE)
  })

  # ── EDA plots ────────────────────────────────────────────────────────────────

  output$eda_recovery_hist <- renderPlotly({
    req(filtered_overview())
    d <- filtered_overview() %>% filter(!is.na(RecoveryScore))
    ql <- quantile(d$RecoveryScore,.01,na.rm=TRUE)
    qh <- quantile(d$RecoveryScore,.99,na.rm=TRUE)
    plot_ly(d, x=~RecoveryScore, type="histogram", nbinsx=150,
            marker=list(color=COL_PRIMARY, opacity=0.8,
                        line=list(color="#FAFAF8",width=0.5))) %>%
      acad_layout("Recovery score", "Count") %>%
      layout(xaxis=list(range=c(ql,qh)))
  })

  output$eda_sleep_hist <- renderPlotly({
    req(filtered_overview())
    d <- filtered_overview() %>% filter(!is.na(TSD), TSD>=3)
    qh <- quantile(d$TSD,.99,na.rm=TRUE)
    plot_ly(d, x=~TSD, type="histogram", nbinsx=80,
            marker=list(color=COL_GOOD, opacity=0.8,
                        line=list(color="#FAFAF8",width=0.5))) %>%
      acad_layout("Sleep duration (h)", "Count") %>%
      layout(xaxis=list(range=c(0,qh)))
  })

  output$eda_sl_hist <- renderPlotly({
    req(filtered_overview())
    d <- filtered_overview() %>%
      filter(!is.na(SL_Intensity)) %>%
      mutate(SL_Intensity=factor(SL_Intensity, levels=c("Rest Day","Light","Moderate","High"))) %>%
      count(SL_Intensity, .drop=FALSE)
    colors <- c("Rest Day"=COL_NEUTRAL,"Light"=COL_GOOD,"Moderate"=COL_WARN,"High"=COL_DANGER)
    plot_ly(d, x=~SL_Intensity, y=~n, type="bar", color=~SL_Intensity, colors=colors,
            text=~n, textposition="outside",
            textfont=list(size=11, family="Lora, serif"),
            marker=list(line=list(color="#FAFAF8",width=0.5)),
            showlegend=FALSE) %>%
      acad_layout("", "N athlete-days")
  })

  output$eda_tv_hist <- renderPlotly({
    req(filtered_overview())
    d <- filtered_overview() %>% filter(!is.na(TV), TV>0)
    qh <- quantile(d$TV,.99,na.rm=TRUE)
    plot_ly(d, x=~TV, type="histogram", nbinsx=150,
            marker=list(color=COL_WARN, opacity=0.8,
                        line=list(color="#FAFAF8",width=0.5))) %>%
      acad_layout("Training volume (km)", "Count") %>%
      layout(xaxis=list(range=c(0,qh)))
  })

  output$eda_missing <- renderPlotly({
    req(filtered_overview())
    n_total <- nrow(filtered_overview())
    d <- filtered_overview() %>%
      summarise(across(everything(), ~sum(is.na(.)))) %>%
      pivot_longer(everything(), names_to="variable", values_to="n_missing") %>%
      mutate(pct=100*n_missing/n_total) %>%
      filter(n_missing>0) %>%
      arrange(desc(pct))
    plot_ly(d, x=~pct, y=~reorder(variable,pct), type="bar", orientation="h",
            marker=list(color=~ifelse(pct>50, COL_DANGER,
                                ifelse(pct>25, COL_WARN, COL_PRIMARY)),
                        opacity=0.82, line=list(color="#FAFAF8",width=0.3)),
            text=~paste0(round(pct,1),"%"), textposition="outside",
            textfont=list(size=10, family="Lora, serif")) %>%
      acad_layout("% missing", "") %>%
      layout(xaxis=list(range=c(0,105)),
             margin=list(l=170, r=60, t=20, b=45))
  })
}

