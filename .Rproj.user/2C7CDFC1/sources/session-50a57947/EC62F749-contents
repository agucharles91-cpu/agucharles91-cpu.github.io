# Load and Prepare Data
# ------------------------------------------------------------------------------
data_path <- "C:/Users/arnel/Downloads/Garmin_project/garmin_analysis_ready.csv"
garmin <- read_csv(data_path, show_col_types = FALSE) %>%
  arrange(User_id, calendar_date)

if (!inherits(garmin$calendar_date, "Date"))
  garmin$calendar_date <- as.Date(garmin$calendar_date)

if (!"RecoveryScore" %in% names(garmin))
  garmin <- garmin %>% mutate(RecoveryScore = -RHR_dev)

garmin <- garmin %>%
  group_by(User_id) %>%
  mutate(NextDayRecovery = lead(RecoveryScore, 1)) %>%
  ungroup()

if ("SL" %in% names(garmin)) {
  sl_values <- garmin$SL[garmin$SL > 0 & !is.na(garmin$SL)]
  sl_breaks <- if (length(sl_values) >= 3)
    quantile(sl_values, probs = c(0.33, 0.67), na.rm = TRUE) else c(100, 300)
  garmin <- garmin %>%
    mutate(SL_Intensity = case_when(
      is.na(SL) | SL == 0 ~ "Rest Day",
      SL <= sl_breaks[1]   ~ "Light",
      SL <= sl_breaks[2]   ~ "Moderate",
      TRUE                 ~ "High"
    ))
}

garmin <- garmin %>%
  mutate(
    RecoveryScore     = -RHR_dev,
    SleepQuality_pct  = (DeepSleepProp + REMSleepProp) * 100,
    SleepQualityLevel = case_when(
      SleepQuality_pct >= 56 ~ "Rebound",
      SleepQuality_pct >= 48 ~ "Excellent",
      SleepQuality_pct >= 38 ~ "Normal",
      SleepQuality_pct >= 30 ~ "Fair",
      TRUE ~ "Poor"
    ),
    RecoveryLevel = case_when(
      RecoveryScore > quantile(RecoveryScore, 0.80, na.rm = TRUE) ~ "Excellent",
      RecoveryScore > quantile(RecoveryScore, 0.60, na.rm = TRUE) ~ "Good",
      RecoveryScore > quantile(RecoveryScore, 0.35, na.rm = TRUE) ~ "Moderate",
      TRUE ~ "Poor"
    ),
    Gender   = ifelse(Sex == "M", "Male", "Female"),
    Weekday  = wday(calendar_date, label = TRUE, abbr = FALSE, week_start = 1),
    IsWeekend = ifelse(Weekday %in% c("Saturday", "Sunday"), "Weekend", "Weekday"),
    
  )

min_date <- min(garmin$calendar_date, na.rm = TRUE)
max_date <- max(garmin$calendar_date, na.rm = TRUE)
users    <- sort(unique(garmin$User_id))

