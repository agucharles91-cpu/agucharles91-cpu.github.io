acad_layout <- function(p, xlab = "", ylab = "") {
  p %>% layout(
    font        = list(family = "Georgia, 'Times New Roman', serif", size = 12, color = "#2B2B2B"),
    paper_bgcolor = "#FAFAF8",
    plot_bgcolor  = "#FAFAF8",
    xaxis = list(
      title      = list(text = xlab, font = list(size = 12)),
      showgrid   = TRUE,
      gridcolor  = "#E8E4DE",
      gridwidth  = 1,
      zeroline   = FALSE,
      tickfont   = list(size = 11),
      linecolor  = "#CCCCCC",
      linewidth  = 1,
      mirror     = TRUE
    ),
    yaxis = list(
      title      = list(text = ylab, font = list(size = 12)),
      showgrid   = TRUE,
      gridcolor  = "#E8E4DE",
      gridwidth  = 1,
      zeroline   = FALSE,
      tickfont   = list(size = 11),
      linecolor  = "#CCCCCC",
      linewidth  = 1,
      mirror     = TRUE
    ),
    margin  = list(l = 55, r = 25, t = 30, b = 55),
    legend  = list(
      bgcolor     = "rgba(250,250,248,0.9)",
      bordercolor = "#CCCCCC",
      borderwidth = 1,
      font        = list(size = 11)
    )
  ) %>%
  config(displayModeBar = FALSE)
}

