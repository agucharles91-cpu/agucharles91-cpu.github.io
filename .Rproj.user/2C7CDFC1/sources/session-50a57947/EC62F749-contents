# Wraps a plotly output in the card + caption structure
fig_card <- function(label, plot_id, height = "310px", caption = NULL) {
  div(class = "acad-card",
    div(class = "card-label", label),
    withSpinner(plotlyOutput(plot_id, height = height),
                type = 6, color = "#2C5F8A", size = 0.6),
    if (!is.null(caption)) div(class = "fig-caption", caption)
  )
}

# Four KPI boxes in a flex row
kpi_row <- function(...) {
  div(class = "kpi-row", ...)
}

kpi_box <- function(label, output_id) {
  div(class = "kpi-box",
    div(class = "kpi-label", label),
    div(class = "kpi-value", textOutput(output_id, inline = TRUE))
  )
}

# Section heading + subhead
page_head <- function(title, subtitle = NULL) {
  tagList(
    div(class = "section-heading", title),
    if (!is.null(subtitle)) div(class = "section-subhead", subtitle)
  )
}

# Italic annotation bar
